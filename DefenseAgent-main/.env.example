# ============================================================
# AGENT_LAB LLM Configuration
# ============================================================
#
# Select the Provider to use.
# Options: openai, anthropic, google, deepseek, qwen, vllm
AGENT_LAB_LLM_PROVIDER=

# ============================================================
# General LLM Override (per-field; highest priority)
# If any of these fields is non-empty, it overrides the
# corresponding provider-specific value below.
# Example: set LLM_MODEL_ID to swap models without editing
# the provider-specific block.
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_ID=

# ============================================================
# OpenAI Configuration
# Leave OPENAI_BASE_URL blank to use the Anthropic SDK default.
# ============================================================
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ============================================================
# Anthropic/Claude Configuration
# Leave ANTHROPIC_BASE_URL blank to use the Anthropic SDK default.
# Set ANTHROPIC_BASE_URL to a proxy URL (e.g. OpenRouter) if routing
# Claude through a compatible proxy.
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# ============================================================
# Google/Gemini Configuration (Via OpenAI-compatible proxy)
# GOOGLE_BASE_URL is required (Gemini has no direct OpenAI endpoint).
# ============================================================
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_MODEL=

# ============================================================
# DeepSeek Configuration
# ============================================================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================================
# Qwen Configuration
# ============================================================
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=

# ============================================================
# vLLM Configuration (Local/Remote vLLM Inference Service)
# vLLM is OpenAI-compatible; use the /v1 endpoint.
# Example: vllm serve Qwen/Qwen2.5-72B-Instruct --port 8000
# ============================================================
VLLM_API_KEY=token-not-needed
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=

# ============================================================
# Embedding Configuration (used by agent_harness.memory)
# Independent from the chat provider above — chat providers
# like DeepSeek and Anthropic (native) don't offer embeddings.
# Supported providers (OpenAI-compatible): openai, qwen, vllm
# ============================================================
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# ============================================================
# General Model Parameters (defaults used by callers when not
# specified per-request). Not wired into adapters yet.
# ============================================================
AGENT_LAB_LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ============================================================
# Optional Web Search (Tavily) — used by future tools.
# ============================================================
TAVILY_API_KEY=

# ============================================================
# Runtime Switches — used by future runtime module.
# ============================================================
AGENT_LAB_DISABLE_BACKGROUND_RUNTIME=false
AGENT_LAB_RUNTIME_AUTONOMOUS_A2A=true
AGENT_LAB_RUNTIME_LLM_DECISIONS=true
